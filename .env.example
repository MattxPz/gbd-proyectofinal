# Cadena de conexión a MongoDB Atlas (mongodb+srv://usuario:password@cluster/...)
MONGODB_URI=

# Puerto en el que arranca la app en local. No es necesario definirla en
# Render: la plataforma inyecta su propio valor de PORT automáticamente.
PORT=5000

# Clave requerida en el header X-API-KEY para POST/PUT/DELETE en /producciones.
# Los GET no la necesitan. Usa un valor propio y secreto, no el de ejemplo.
API_KEY=cambia-esto-por-una-clave-segura
